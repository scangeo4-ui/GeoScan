{
  "name": "geo-scan",
  "version": "1.0.0",
  "description": "Sistema de monitoramento geológico com visualização 3D",
  "main": "dist/server.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd Backend && ts-node-dev --respawn --transpile-only src/server/server.ts",
    "dev:client": "cd Frontend && vite",
    "build": "npm run build:server && npm run build:client",
    "build:server": "cd Backend && tsc --project tsconfig.json",
    "build:client": "cd Frontend && vite build",
    "start": "node dist/server.js",
    "test": "jest",
    "lint": "eslint src/**/*.{ts,tsx} --fix"
  },
  "keywords": ["geology", "monitoring", "3d", "react", "typescript"],
  "author": "Mechack777",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.1",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.17",
    "axios": "^1.6.2",
    "three": "^0.158.0",
    "@react-three/fiber": "^8.15.11",
    "@react-three/drei": "^9.88.13",
    "framer-motion": "^10.16.16",
    "lucide-react": "^0.294.0",
    "leaflet": "^1.9.4",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.16",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "@types/three": "^0.158.0",
    "@types/leaflet": "^1.9.8",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  }
}